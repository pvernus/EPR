# === WHITELIST — only explicitly allowed files are tracked ===

# Ignore everything at root level
/*

# Root files to track
!.gitignore
!GODAD.Rproj
!README.md

# Root folders to track (all contents)
!CerdiSeminar/
!paper/

# data/ folder: track .gitkeep (forces data/ to appear as its own folder) and .qmd files
!data/
/data/**
!/data/.gitkeep
!/data/**/
!/data/**/*.qmd

# source/ folder: track sub-folder structure only, no files
!source/
/source/**
!/source/**/
!/source/**/.gitkeep

# script/ folder: track all files
!script/

# output/ folder: fully ignored
/output/
